{
  "containerDefinitions": [
    {
      "cpu": 0,
      "dependsOn": [
        {
          "condition": "COMPLETE",
          "containerName": "crowdstrike-falcon-init-container"
        }
      ],
      "entryPoint": [
        "/tmp/CrowdStrike/rootfs/lib/ld-linux-aarch64.so.1",
        "--library-path",
        "/tmp/CrowdStrike/rootfs/lib64",
        "/tmp/CrowdStrike/rootfs/bin/bash",
        "/tmp/CrowdStrike/rootfs/entrypoint-ecs.sh",
        "/entrypoint.sh"
      ],
      "environment": [
        {
          "name": "FALCONCTL_OPTS",
          "value": "--cid=AAAABBBBCCCCDDDDEEEEFFFFGGGGHHH1-00"
        }
      ],
      "essential": true,
      "image": "123456789012.dkr.ecr.us-east-1.amazonaws.com/my-ecr-repo:detection-container-vulnapp-latest",
      "linuxParameters": {
        "capabilities": {
          "add": ["SYS_PTRACE"]
        }
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-create-group": "true",
          "awslogs-group": "/ecs/vulnapp-falcon-lab",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "vulnapp"
        }
      },
      "mountPoints": [
        {
          "containerPath": "/tmp/CrowdStrike",
          "readOnly": true,
          "sourceVolume": "crowdstrike-falcon-volume"
        }
      ],
      "name": "vulnapp",
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "systemControls": [],
      "volumesFrom": []
    },
    {
      "entryPoint": [
        "/bin/bash",
        "-c",
        "chmod u+rwx /tmp/CrowdStrike \u0026\u0026 mkdir -p /tmp/CrowdStrike/rootfs/lib \u0026\u0026 cp /lib/ld-linux-aarch64.so.1 /tmp/CrowdStrike/rootfs/lib/  \u0026\u0026 cp -r /bin /etc /lib64 /usr /entrypoint-ecs.sh /tmp/CrowdStrike/rootfs \u0026\u0026 chmod -R a=rX /tmp/CrowdStrike"
      ],
      "essential": false,
      "image": "123456789012.dkr.ecr.us-east-1.amazonaws.com/my-ecr-repo:falcon-lumos-sensor-latest",
      "mountPoints": [
        {
          "containerPath": "/tmp/CrowdStrike",
          "readOnly": false,
          "sourceVolume": "crowdstrike-falcon-volume"
        }
      ],
      "name": "crowdstrike-falcon-init-container",
      "readonlyRootFilesystem": true,
      "user": "0:0"
    },
    {
      "name": "nginx-tls-proxy",
      "image": "123456789012.dkr.ecr.us-east-1.amazonaws.com/my-ecr-repo:nginx-tls-proxy",
      "cpu": 0,
      "command": ["nginx", "-g", "daemon off;"],
      "portMappings": [
        {
          "containerPort": 443,
          "hostPort": 443,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [],
      "dockerLabels": {
        "sensor.falcon-system.crowdstrike.com/injection": "disabled"
      },
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/vulnapp-falcon-lab",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "nginx-proxy"
        }
      },
      "systemControls": []
    }
  ],
  "cpu": "512",
  "executionRoleArn": "arn:aws:iam::123456789012:role/my-ecs-execution-role",
  "family": "vulnapp-falcon-lab",
  "memory": "1024",
  "networkMode": "awsvpc",
  "placementConstraints": [],
  "requiresCompatibilities": ["FARGATE"],
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "volumes": [
    {
      "name": "crowdstrike-falcon-volume"
    }
  ]
}
