{
  "containerDefinitions": [
    {
      "name": "vulnapp",
      "image": "123456789012.dkr.ecr.us-east-1.amazonaws.com/my-ecr-repo:detection-container-vulnapp-latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/vulnapp-falcon-lab",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "vulnapp"
        }
      },
      "systemControls": []
    },
    {
      "name": "nginx-tls-proxy",
      "image": "123456789012.dkr.ecr.us-east-1.amazonaws.com/my-ecr-repo:nginx-tls-proxy",
      "cpu": 0,
      "command": ["nginx", "-g", "daemon off;"],
      "portMappings": [
        {
          "containerPort": 443,
          "hostPort": 443,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [],
      "dockerLabels": {
        "sensor.falcon-system.crowdstrike.com/injection": "disabled"
      },
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/vulnapp-falcon-lab",
          "awslogs-create-group": "true",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "nginx-proxy"
        }
      },
      "systemControls": []
    }
  ],
  "family": "vulnapp-falcon-lab",
  "executionRoleArn": "arn:aws:iam::123456789012:role/my-ecs-execution-role",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024"
}
